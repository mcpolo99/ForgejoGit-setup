# =========================
# GENERAL
# =========================
TZ=Europe/Stockholm

# Domain (used by Traefik routing + Forgejo config)
HOSTNAME=git.mydomain.com

# =========================
# USER / PERMISSIONS (Linux containers)
# =========================
UID=1000
GID=1000

# SSH access for Git
SSH_PORT=2222

# =========================
# POSTGRESQL (Forgejo DB)
# =========================
POSTGRES_DB=forgejo
POSTGRES_USER=forgejo
# openssl rand -hex 24 
POSTGRES_PASSWORD=change_me_strong_password

# =========================
# FORGEJO SERVER
# =========================

# Local: http://localhost:3000/
# Prod:  https://git.mydomain.com/
ROOT_URL=http://localhost:3000/

# =========================
# FORGEJO VISIBILITY / ACCESS
# =========================
FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_REQUIRE_SIGNIN=true
FORGEJO_DEFAULT_REPO_PRIVATE=true
FORGEJO_DEFAULT_USER_VISIBILITY=private
FORGEJO_DEFAULT_ORG_VISIBILITY=private

# =========================
# BACKUPS
# =========================
BACKUP_CRON=0 3 * * *
BACKUP_KEEP_DAYS=30

# =========================
# TRAEFIK / TLS CONTROL
# =========================

# Email used for Let's Encrypt registration (required in prod)
ACME_EMAIL=you@mydomain.com

# =========================
# AZURE DNS (ACME DNS-01)
# Required ONLY for production TLS
# =========================
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=your-dns-resource-group
AZURE_ZONE_NAME=mydomain.com

# =========================
# OPTIONAL FUTURE EXTENSIONS
# =========================

# For future SSO (Authentik, Keycloak, etc.)
AUTH_ENABLED=false

# For future CI runners
CI_ENABLED=false

# Logging level placeholder
LOG_LEVEL=info
